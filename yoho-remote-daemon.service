[Unit]
Description=Yoho Remote Daemon
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=yoho
WorkingDirectory=/home/yoho/.yoho-remote
EnvironmentFile=/home/yoho/.yoho-remote/daemon.systemd.env
ExecStart=/opt/yoho-remote/yoho-remote-daemon
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
