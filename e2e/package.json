{
    "name": "yoho-remote-e2e",
    "private": true,
    "version": "0.1.0",
    "type": "module",
    "scripts": {
        "smoke": "bun run src/runPlaywright.ts test --config=playwright.config.ts --project=chromium-smoke",
        "full": "bun run src/runPlaywright.ts test --config=playwright.config.ts",
        "test": "bun run smoke",
        "typecheck": "tsc --noEmit",
        "mock:api": "bun run src/mocks/runMockApi.ts",
        "smoke:fake-deepseek": "cd .. && bun run smoke:fake-deepseek"
    },
    "dependencies": {
        "@socket.io/bun-engine": "^0.1.0",
        "hono": "^4.11.2",
        "jose": "^6.1.3",
        "socket.io": "^4.8.3",
        "socket.io-client": "^4.8.3"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.0",
        "@types/node": ">=25",
        "bun-types": "^1.3.5",
        "typescript": "^5"
    }
}
