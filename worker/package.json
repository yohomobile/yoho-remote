{
    "name": "yoho-remote-worker",
    "private": true,
    "version": "0.1.0",
    "type": "module",
    "scripts": {
        "start": "bun run src/index.ts",
        "dev": "bun --watch run src/index.ts",
        "test": "bun test",
        "typecheck": "tsc --noEmit",
        "build": "bun build src/index.ts --outdir dist --target bun",
        "build:exe": "bun build src/index.ts --compile --outfile dist-exe/yoho-remote-worker"
    },
    "dependencies": {
        "pg": "^8.16.3",
        "pg-boss": "^12.15.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/node": ">=25",
        "@types/pg": "^8.16.0",
        "bun-types": "^1.3.5",
        "typescript": "^5"
    }
}
